FROM node:22-alpine AS build

WORKDIR /app

COPY package*.json ./
RUN npm ci

COPY . .
RUN npm run build

FROM node:22-alpine

WORKDIR /app

COPY package*.json ./
RUN npm ci --only=production && npm install express

COPY --from=build /app/dist /app/dist
COPY server.js ./

EXPOSE 8080

CMD ["node", "server.js"]
